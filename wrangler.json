{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "libro",
  "account_id": "5863bd5f917df7319a565284f8ae8422",
  "main": "src/server.ts",
  "compatibility_date": "2026-04-12",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],
  "r2_buckets": [
    {
      "binding": "WORKSPACE_R2",
      "bucket_name": "libro"
    }
  ],
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*"]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "nlwebs_NLWebMcp",
        "class_name": "name"
      }
    ]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
